#!/usr/bin/env zsh

emulate -R zsh

DOTFILES_COMMAND_PATH="${0:A}"

function die() {
    print -u2 -r -- "dotfiles: $*"
    exit 1
}

function usage() {
    cat <<'EOF'
Usage:
  dotfiles option list
  dotfiles option show <name>
  dotfiles option on <name>
  dotfiles option off <name>
  dotfiles option toggle <name>

Commands:
  option    Manage local dotfiles options.
EOF
}

function option_usage() {
    cat <<'EOF'
Usage:
  dotfiles option list
  dotfiles option show <name>
  dotfiles option on <name>
  dotfiles option off <name>
  dotfiles option toggle <name>
EOF
}

function repo_dir_from_script() {
    emulate -L zsh
    local script_path="$DOTFILES_COMMAND_PATH"
    local candidate="${script_path:h:h}"

    if [[ -r "$candidate/.config/zsh/sync/dotfiles.zsh" ]]; then
        print -r -- "$candidate"
        return 0
    fi

    if [[ -r "$HOME/dotfiles/.config/zsh/sync/dotfiles.zsh" ]]; then
        print -r -- "$HOME/dotfiles"
        return 0
    fi

    print -r -- "${DOTFILES_DIR:-$HOME/dotfiles}"
}

function load_options() {
    emulate -L zsh
    local options_file="$DOTFILES_DIR/.config/zsh/sync/dotfiles.zsh"

    [[ -r "$options_file" ]] || die "options file not found: $options_file"
    source "$options_file"
}

function require_option() {
    emulate -L zsh
    local name="${1:-}"

    [[ -n "$name" ]] || die "option name is required"
    dotfiles_option_exists "$name" || die "unknown option: $name"
}

function write_option_state() {
    emulate -L zsh
    local changed_name="$1"
    local changed_value="$2"
    local state_file state_dir name value
    typeset -A values

    require_option "$changed_name"
    state_file="$(dotfiles_options_state_file)"
    state_dir="${state_file:h}"

    mkdir -p "$state_dir" || die "failed to create state directory: $state_dir"

    for name in "${DOTFILES_OPTION_NAMES[@]}"; do
        value="$(dotfiles_option_value "$name")" || die "failed to read option: $name"
        values[$name]="$value"
    done
    values[$changed_name]="$changed_value"

    {
        print -r -- "# Generated by dotfiles option. Edit with: dotfiles option on|off|toggle <name>"
        print -r -- ""
        for name in "${DOTFILES_OPTION_NAMES[@]}"; do
            print -r -- "zstyle ':dotfiles:options' $name ${values[$name]}"
        done
    } >| "$state_file" || die "failed to write state file: $state_file"

    print -r -- "$changed_name: $changed_value"
}

function option_list() {
    emulate -L zsh
    local name value default description

    printf "%-16s %-7s %-7s %s\n" "NAME" "VALUE" "DEFAULT" "DESCRIPTION"
    for name in "${DOTFILES_OPTION_NAMES[@]}"; do
        value="$(dotfiles_option_value "$name")"
        default="${DOTFILES_OPTION_DEFAULTS[$name]}"
        description="${DOTFILES_OPTION_DESCRIPTIONS[$name]}"
        printf "%-16s %-7s %-7s %s\n" "$name" "$value" "$default" "$description"
    done
}

function option_show() {
    emulate -L zsh
    local name="$1"

    require_option "$name"
    print -r -- "name: $name"
    print -r -- "value: $(dotfiles_option_value "$name")"
    print -r -- "default: ${DOTFILES_OPTION_DEFAULTS[$name]}"
    print -r -- "state-file: $(dotfiles_options_state_file)"
    print -r -- "description: ${DOTFILES_OPTION_DESCRIPTIONS[$name]}"
}

function option_toggle() {
    emulate -L zsh
    local name="$1"

    require_option "$name"
    if dotfiles_option_enabled "$name"; then
        write_option_state "$name" no
    else
        write_option_state "$name" yes
    fi
}

function option_command() {
    emulate -L zsh
    local command="${1:-list}"

    shift $(( $# > 0 ? 1 : 0 ))

    case "$command" in
        list)
            [[ $# -eq 0 ]] || die "option list does not take arguments"
            option_list
            ;;
        show)
            [[ $# -eq 1 ]] || die "usage: dotfiles option show <name>"
            option_show "$1"
            ;;
        on | enable)
            [[ $# -eq 1 ]] || die "usage: dotfiles option on <name>"
            require_option "$1"
            write_option_state "$1" yes
            ;;
        off | disable)
            [[ $# -eq 1 ]] || die "usage: dotfiles option off <name>"
            require_option "$1"
            write_option_state "$1" no
            ;;
        toggle)
            [[ $# -eq 1 ]] || die "usage: dotfiles option toggle <name>"
            option_toggle "$1"
            ;;
        help | --help | -h)
            option_usage
            ;;
        *)
            die "unknown option command: $command"
            ;;
    esac
}

DOTFILES_DIR="${DOTFILES_DIR:-$(repo_dir_from_script)}"
export DOTFILES_DIR
load_options

case "${1:-help}" in
    option)
        shift
        option_command "$@"
        ;;
    help | --help | -h)
        usage
        ;;
    *)
        die "unknown command: $1"
        ;;
esac
